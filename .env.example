# ============================================================
# Enterprise ETL Platform - Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Application ────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=false

# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://etl_user:etl_pass@localhost:5432/etl_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Airflow ────────────────────────────────────────────────
AIRFLOW_API_URL=http://localhost:8080
AIRFLOW_USER=airflow
AIRFLOW_PASSWORD=airflow
AIRFLOW_UID=50000

# ── Email Alerting ─────────────────────────────────────────
# Set EMAIL_ALERTS_ENABLED=true and fill these to enable email alerts
EMAIL_ALERTS_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL=alerts@yourcompany.com

# ── Slack Alerting ─────────────────────────────────────────
# Set SLACK_ALERTS_ENABLED=true and paste your Incoming Webhook URL
SLACK_ALERTS_ENABLED=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── Data Quality Defaults ──────────────────────────────────
DEFAULT_QUALITY_THRESHOLD=0.80
MAX_NULL_RATIO=0.20
MAX_DUPLICATE_RATIO=0.05

# ── Pipeline Settings ──────────────────────────────────────
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_SECONDS=60
CONFIG_DIR=/app/configs
DATA_DIR=/app/data
